}

.confirmationButtonRow{
    flex-direction: row;
    justify-content: center;
    align-items: center;
    margin-top: 8px;
}

.confirmUseButton{
    flex-grow : 1;
    margin-right: 4px;
    color: white;
    background-color: rgb(38, 138, 78);
}

.goBackButton {
    flex-grow: 1;
    margin-left: 4px;
}

.unity-scroller__low-button {
    display: none;
}

.unity-scroller__high-button {
    display: none;
}

.unity-scroller--vertical {
    width: 10px;
    border-color: rgba(0, 0, 0, 0);
    background-color: rgba(0, 0, 0, 0);
}


.unity-base-slider__tracker {
    background-color: rgba(0, 0, 0, 0);
    border-color: rgba(0, 0, 0, 0);
}


.unity-base-slider__dragger {
    background-color: rgb(80, 80, 80);
    border-radius: 5px;
    width: 8px;
    left: 1px;
}

.unity-scroller--horizontal {
    display: none;
}

.divider {
    height: 5px;
    background-color: rgba(3, 252, 48, 0.5);
    margin-top: 4px;
    margin-bottom: 4px;
    flex-grow: 0;
    flex-shrink: 0;
}

.inventory-row {
    width: 100%;
    min-height: 64px;
    margin-bottom: 8px;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
}

.inventory-subheader {
    color: rgb(255, 255, 255);
    font-size: 12px;
    margin-bottom: 8px;
}


.inventory-brand-visual {
    width: 42px;
    height: 42px;
    margin-right: 10px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
    background-color: rgba(255, 255, 255, 0.2);
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.85);
    border-bottom-color: rgba(255, 255, 255, 0.85);
    border-left-color: rgba(255, 255, 255, 0.85);
    border-right-color: rgba(255, 255, 255, 0.85);
}
